DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

AUTH_SECRET="replace-with-a-random-secret"
AUTH_URL="http://localhost:3000"
# Canonical public site URL — used for SEO canonicals, OpenGraph/Twitter tags,
# and the sitemap. Set this in production (no trailing slash). On Vercel,
# VERCEL_URL is used automatically if this is unset; dev falls back to localhost.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"

RESEND_API_KEY="replace-with-resend-api-key"
EMAIL_FROM="FamilyPulse <no-reply@example.com>"

DO_SPACES_REGION="nyc3"
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_BUCKET="your-space-name"
DO_SPACES_KEY="replace-with-spaces-key"
DO_SPACES_SECRET="replace-with-spaces-secret"
DO_SPACES_CDN_ENDPOINT="https://your-space-name.nyc3.cdn.digitaloceanspaces.com"

# Secret shared with Vercel Cron to authorize the scheduled AI draft generator.
# You can generate this from /admin/settings (stored encrypted in the DB); set
# the SAME value here / in the Vercel project's Environment Variables so the
# scheduled invocation is authorized.
CRON_SECRET="replace-with-a-long-random-secret"

# AI draft generation. These can also be managed (and encrypted) from
# /admin/settings; env values act as a fallback. The provider/interval/etc.
# below are optional — sensible defaults apply when unset.
ANTHROPIC_API_KEY="sk-ant-..."
DEEPSEEK_API_KEY="sk-..."
# Cover images: choose the provider with AI_DRAFTS_IMAGE_PROVIDER ("openai" | "gemini").
AI_DRAFTS_IMAGE_PROVIDER="openai"
# OpenAI image generation (default model gpt-image-1).
OPENAI_API_KEY="sk-..."
# Optional: image model and quality (low | medium | high | auto). Default medium.
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_QUALITY="medium"
# Google Gemini image generation (used when AI_DRAFTS_IMAGE_PROVIDER="gemini").
GEMINI_API_KEY="AIza..."
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
AI_DRAFTS_ENABLED="false"
AI_DRAFTS_PROVIDER="anthropic"
AI_DRAFTS_INTERVAL_MINUTES="60"
AI_DRAFTS_PER_RUN="1"
AI_DRAFTS_COVER_IMAGES="true"

# Google AdSense (also configurable in Site Settings → Advertising).
# Publisher id powers in-post Advert blocks and site-wide Auto ads.
ADSENSE_CLIENT_ID="ca-pub-XXXXXXXXXXXXXXXX"
# Site-wide Auto ads on public pages ("true" to enable; also enable Auto ads in the AdSense console).
ADSENSE_AUTO_ADS="false"

# Facebook Page auto-post (also configurable in Site Settings → Facebook Auto-post).
# Shares each post to a Facebook Page (as a link post) the first time it's published.
FACEBOOK_AUTOPOST_ENABLED="false"
FACEBOOK_PAGE_ID="1234567890"
# Long-lived Page Access Token with pages_manage_posts permission.
FACEBOOK_PAGE_ACCESS_TOKEN="EAA..."
# Graph API version (defaults to v25.0 when blank).
FACEBOOK_GRAPH_VERSION="v25.0"

# WhatsApp Cloud API (also configurable in Site Settings → WhatsApp Messaging).
# Webhook callback URL to register in Meta (App → WhatsApp → Configuration):
#   https://<your-domain>/api/whatsapp
# Auto-reply to inbound messages when "true"; webhook still verifies/logs when off.
WHATSAPP_ENABLED="false"
# Cloud API phone number id (NOT the phone number) used to send messages.
WHATSAPP_PHONE_NUMBER_ID="1234567890"
# WhatsApp Business Account id (WABA) for account-level Graph calls (templates, numbers).
WHATSAPP_BUSINESS_ACCOUNT_ID="1234567890"
# Access token with whatsapp_business_messaging permission (system user / long-lived).
WHATSAPP_ACCESS_TOKEN="EAA..."
# Arbitrary string you choose; enter the SAME value in Meta's webhook config (GET handshake).
WHATSAPP_VERIFY_TOKEN="replace-with-a-random-verify-token"
# Meta App Secret — verifies the X-Hub-Signature-256 on incoming webhooks (required).
WHATSAPP_APP_SECRET="replace-with-meta-app-secret"
# Graph API version (defaults to v25.0 when blank).
WHATSAPP_GRAPH_VERSION="v25.0"
