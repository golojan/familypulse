generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  EDITOR
  SUPERADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum PostType {
  ARTICLE
  VIDEO
  PODCAST
}

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum MediaStatus {
  PENDING
  READY
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  roles         Role[]    @default([USER])
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  mediaAssets   MediaAsset[]

  /** Set when the reader subscribes (global newsletter opt-in). Subscribers see
   * full post bodies; non-subscribers get the gated preview. */
  subscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Topic {
  id           String  @id @default(cuid())
  title        String
  slug         String  @unique
  description  String?
  icon         String  @default("MessageCircle")
  writerPrompt String?
  parentId     String?
  parent       Topic?  @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  subtopics    Topic[] @relation("TopicTree")
  posts        Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  type        PostType   @default(ARTICLE)
  excerpt     String?
  coverImage  String?
  videoUrl    String?
  audioUrl    String?
  blocks      Json       @default("[]")
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  /// When the automated audit (see app/api/cron/audit) last checked this post.
  /// Null means never audited; the audit processes the least-recently-audited first.
  lastAuditedAt DateTime?

  /// Facebook post id once this post has been auto/manually shared to the Page.
  /// Set means "already shared" — used to avoid duplicate posts on republish.
  facebookPostId String?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([topicId])
  @@index([status, publishedAt])
}

model MediaAsset {
  id          String      @id @default(cuid())
  key         String      @unique
  url         String
  filename    String
  alt         String?
  kind        MediaKind
  status      MediaStatus @default(PENDING)
  contentType String
  size        Int

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedById, createdAt])
  @@index([kind])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// Persisted site configuration, keyed by a stable setting key (e.g. "AUTH_GOOGLE_ID").
/// Secret values are stored encrypted (see lib/crypto.ts); `encrypted` marks which.
model SiteSetting {
  key       String   @id
  value     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

enum WhatsAppDirection {
  INBOUND
  OUTBOUND
}

/// Every WhatsApp message that flows through the business number, captured from
/// the Cloud API webhook (inbound) and our send helper (outbound). `messageId`
/// is the WhatsApp wamid and is unique so redelivered webhooks don't duplicate
/// rows. `raw` keeps the original payload fragment for fidelity/debugging.
model WhatsAppMessage {
  id            String            @id @default(cuid())
  direction     WhatsAppDirection
  /// WhatsApp message id (wamid...). Unique per message for idempotent capture.
  messageId     String?           @unique
  /// Sender wa_id (international format, no "+"). The customer's number.
  fromNumber    String
  /// Recipient wa_id. For inbound this is our number/phone-number-id context.
  toNumber      String?
  /// Our Cloud API phone number id that received/sent the message.
  phoneNumberId String?
  /// WhatsApp message type: text, image, audio, button, interactive, etc.
  type          String            @default("text")
  /// Human-readable body for text/button/interactive; empty for media-only.
  body          String?
  /// When WhatsApp reported the message was sent (from the payload), when present.
  sentAt        DateTime?
  /// Original payload fragment for this message, for debugging/fidelity.
  raw           Json?

  createdAt DateTime @default(now())

  @@index([fromNumber, createdAt])
  @@index([direction, createdAt])
}

enum AiDraftRunStatus {
  SUCCESS
  PARTIAL
  FAILED
}

/// Audit + interval gate for the scheduled AI draft generator. The most recent
/// row's `createdAt` is what the cron route compares against the configured
/// interval to decide whether enough time has elapsed to run again.
model AiDraftRun {
  id        String           @id @default(cuid())
  status    AiDraftRunStatus
  provider  String
  model     String
  /// How the run was started: "cron" (scheduled) or "manual" (admin button).
  trigger   String           @default("cron")
  /// Number of draft posts created by this run.
  created   Int              @default(0)
  /// Free-text error/summary for the admin UI when something went wrong.
  detail    String?
  /// Ids of posts created, for traceability.
  postIds   String[]         @default([])

  createdAt DateTime @default(now())

  @@index([createdAt])
}
